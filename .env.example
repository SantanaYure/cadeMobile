# App
EXPO_PUBLIC_APP_NAME=Cadê?
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_APP_VERSION=1.0.0

# API
# Deixe vazio enquanto não existir backend.
EXPO_PUBLIC_API_URL=

# IA
# No MVP, use mock. Não coloque chave real de IA no app mobile.
EXPO_PUBLIC_AI_PROVIDER=mock
EXPO_PUBLIC_AI_ENABLED=false

# Features
# Observação: nesta primeira versão do MVP estas flags são apenas scaffolding
# para o futuro. O app ainda não faz gating de funcionalidades por elas.
EXPO_PUBLIC_ENABLE_FILE_PICKER=true
EXPO_PUBLIC_ENABLE_AI_SUGGESTIONS=true
EXPO_PUBLIC_ENABLE_DUPLICATE_DETECTION=true
EXPO_PUBLIC_ENABLE_LOCAL_STORAGE=false

# Debug
EXPO_PUBLIC_DEBUG_MODE=true
EXPO_PUBLIC_LOG_LEVEL=debug
